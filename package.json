{
  "name": "maestro-router",
  "version": "0.2.0",
  "description": "A CLI wrapper that classifies each Claude Code prompt and routes it to the optimal model + thinking budget. Works on subscription, no API key required.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.3",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmb/maestro-router.git"
  },
  "files": [
    "dist",
    "evals/labeled.jsonl",
    "evals/baseline.json",
    "hooks",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "maestro": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild": "tsx scripts/check-exemplars-checksum.ts",
    "build": "tsc && cp src/classifiers/exemplars.json dist/classifiers/exemplars.json && chmod +x dist/cli/index.js",
    "embed": "tsx scripts/embed.ts",
    "eval": "tsx evals/run.ts",
    "verify": "pnpm dlx publint && pnpm dlx @arethetypeswrong/cli --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@xenova/transformers": "^2.17.2",
    "eslint": "^9.18.0",
    "publint": "^0.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  }
}
