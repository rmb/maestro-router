{
  "name": "maestro-router",
  "version": "0.5.0",
  "description": "Automatic per-prompt model routing for Claude Code — cut AI costs 60–80% without changing how you work. Routes trivial prompts to Haiku and complex ones to Opus. No API key required.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.3",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "llm",
    "ai",
    "cost-optimization",
    "model-routing",
    "haiku",
    "sonnet",
    "opus",
    "cli",
    "developer-tools",
    "token-optimization",
    "ai-cost",
    "claude-wrapper"
  ],
  "homepage": "https://github.com/rmb/maestro-router#readme",
  "bugs": {
    "url": "https://github.com/rmb/maestro-router/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmb/maestro-router.git"
  },
  "files": [
    "dist",
    "evals/labeled.jsonl",
    "evals/baseline.json",
    "hooks",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "maestro": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild": "tsx scripts/check-exemplars-checksum.ts",
    "build": "tsc && cp src/classifiers/exemplars.json dist/classifiers/exemplars.json && mkdir -p dist/data && cp data/model-pricing.json dist/data/model-pricing.json && chmod +x dist/cli/index.js",
    "embed": "tsx scripts/embed.ts",
    "eval": "tsx evals/run.ts",
    "verify": "pnpm dlx publint && pnpm dlx @arethetypeswrong/cli --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@huggingface/transformers": "^3.0.0 || ^4.0.0",
    "eslint": "^9.18.0",
    "publint": "^0.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0 || ^4.0.0",
    "langfuse": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "langfuse": {
      "optional": true
    }
  }
}
